model PropertyImage {
  id String @id @default(uuid())

  propertyId String
  publicId String

  url String @db.Text
  isThumbnail Boolean @default(false)
  
  property Property @relation(fields: [propertyId],references: [id],onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("property_images")
}