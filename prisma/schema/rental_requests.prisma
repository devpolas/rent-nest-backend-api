model RentalRequests{
  id String @id @default(uuid())

  tenantId String
  propertyId String
  landlordId String

  message String @db.Text

  moveInDate DateTime
  leaseMonths Int

  property Property @relation(fields: [propertyId],references: [id],onDelete: Cascade)

  tenant User @relation( name: "tenant", fields: [tenantId],references: [id],onDelete: Cascade)

  landlord User @relation(name:"landlord",fields: [landlordId], references: [id],onDelete: Cascade)

  status RentalRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId,tenantId])
  @@index([tenantId])
  @@index([propertyId])
  
  @@unique([tenantId, propertyId])

  @@map("rental_requests")
}