model Location {
  id String @id @default(uuid())

  latitude  String?  @db.Text
  longitude String? @db.Text

  type LocationType
  country    String
  division   String
  district   String
  city       String
  village    String
  postalCode String

  addressLine String? @db.Text

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  property Property?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([division])
  @@index([district])
  @@index([city])
  @@index([postalCode])
  @@index([profileId])

  @@map("locations")
}